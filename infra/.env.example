POSTGRES_DB=wikiwatch
POSTGRES_USER=wikiwatch
POSTGRES_PASSWORD=wikiwatch
DATABASE_URL=postgresql://wikiwatch:wikiwatch@postgres:5432/wikiwatch
DATABASE_URL_LOCAL=postgresql://wikiwatch:wikiwatch@localhost:5432/wikiwatch
NEXT_PUBLIC_APP_NAME=WikiWatch
WIKIMEDIA_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
WORKER_USER_AGENT=WikiWatchBot/1.0 (https://wikiwatch.vercel.app; example@email.com)
WORKER_STREAM_READ_TIMEOUT_SECONDS=120
WORKER_TOP_PAGES_LIMIT=20
WORKER_BATCH_SIZE=100
WORKER_FLUSH_INTERVAL_SECONDS=5
WORKER_RECONNECT_DELAY_SECONDS=3
WORKER_LOG_LEVEL=INFO
WORKER_STORE_RAW_JSON=false
RAW_EDITS_RETENTION_DAYS=3
RETENTION_CHECK_INTERVAL_SECONDS=3600
